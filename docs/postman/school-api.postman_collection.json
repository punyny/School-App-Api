{
  "info": {
    "_postman_id": "6ea3f77a-5b94-4d60-8948-41e1435de2ec",
    "name": "School API (Laravel)",
    "description": "Core API requests for School Management system.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\",\n  \"device_name\": \"postman\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "List Attendance",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/attendance?class_id={{class_id}}"
          }
        },
        {
          "name": "Create Attendance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/attendance",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_id\": {{student_id}},\n  \"class_id\": {{class_id}},\n  \"date\": \"2026-03-09\",\n  \"time_start\": \"08:00\",\n  \"time_end\": \"09:00\",\n  \"status\": \"P\"\n}"
            }
          }
        },
        {
          "name": "Export Attendance CSV",
          "request": {
